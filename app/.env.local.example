# Copy to .env.local and fill in after deploying the Workers in ../worker and ../worker-market-data.

# wss:// URL of the blind sync relay Worker's WebSocket endpoint, e.g.
# wss://first-bank-of-dad-relay.<your-subdomain>.workers.dev/ws
NEXT_PUBLIC_RELAY_URL=

# https:// URL of the market-data Worker's GET endpoint, e.g.
# https://first-bank-of-dad-market-data.<your-subdomain>.workers.dev/market-data
NEXT_PUBLIC_MARKET_DATA_URL=
